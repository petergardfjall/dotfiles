#!/bin/bash

#
# source all files in ~/dotfiles/bash
#
for f in $(find ~/dotfiles/bash -maxdepth 1 -name '*.env'); do
    [[ -f ${f} ]] && source ${f}
done

#
# source all files in ~/dotfiles/bash/bash.local
#
for f in $(find ~/dotfiles/bash/bash.local/ -maxdepth 1 -name '*.env'); do
    [[ -f ${f} ]] && source ${f}
done
