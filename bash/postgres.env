#
# 'psql-local [mydatabase]' accesses a local development database with 'psql'.
#
function psql-local() {
    export PGUSER=postgres PGPASSWORD=password PGHOST=localhost PGDATABASE=${1}
    psql
}

#
# 'psql-kind [mydatabase]' access a local development database with 'psql'
# inside kind.
#
function psql-kind() {
    export PGUSER=postgres PGPASSWORD=password PGHOST=postgres.local.svc.cluster.local PGDATABASE=${1}
    # telepresence --namespace=local --run psql
    user_daemon_status=$(telepresence status --output json | jq -r .user_daemon.status)
    if [ "${user_daemon_status}" != "Connected" ]; then
       echo "error: telepresence status indicates that user daemon is not connected to cluster"
    else
       psql
    fi
}


# equivalent to always running with "\psql pager off"
export PSQL_PAGER=
