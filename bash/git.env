#
# Updates the master branch of every unmodified repository rooted under the current directory.
#
function git-update-master() {
  root_dir=${pwd}
  for sub_folder in $(find ${root_dir} -maxdepth 2 -name .git -type d | xargs dirname | sort); do
    pushd ${sub_folder} > /dev/null
    {
      if [ -z "$(git status --porcelain --untracked-files=no)" ]; then       
         echo "updating master for ${sub_folder} ..."
         current_branch=$(git branch --show-current)
         echo "switch branch: ${current_branch} => master ..."
         git checkout master && git fetch --prune && git merge origin/master
         git checkout ${current_branch}
      fi
    }
    popd > /dev/null
  done
}