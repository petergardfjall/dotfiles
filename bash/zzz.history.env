#
# Additional settings for bash history.
#
# Note: filename is only to make sure that this appears after any other files
#       that modify PROMPT_COMMAND.

# History length see HISTSIZE and HISTFILESIZE in bash(1)
export HISTSIZE=10000     # Max history size in memory.
export HISTFILESIZE=10000 # Max history file size on disk.

# Avoid duplicate entries.
export HISTCONTROL="ignoredups:erasedups"
# Ignore certain commands from the history.
export HISTIGNORE=”exit:clear:htop*:history*:rm*”

# Force shell to write to .bash_history after each command (not only after shell
# exit).
export PROMPT_COMMAND="history -a; $PROMPT_COMMAND"
